{
  "name": "aotakeuma",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run typegen && react-router dev",
    "dev:remote": "pnpm run typegen && NODE_ENV=development react-router build && wrangler dev --remote",
    "build": "pnpm run typegen && react-router build",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "lint": "prettier . --check && eslint",
    "fix": "prettier . --write && eslint --fix",
    "postinstall": "pnpm run typegen",
    "typegen": "pnpm run typegen:cloudflare && pnpm run typegen:react-router",
    "typegen:cloudflare": "wrangler types",
    "typegen:react-router": "react-router typegen",
    "test": "vitest run --config vitest.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "hono": "^4.12.23",
    "isbot": "^5.1.40",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@cloudflare/vite-plugin": "^1.35.0",
    "@react-router/dev": "^7.12.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.3.6",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.1",
    "storybook-addon-remix-react-router": "^6.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.6",
    "wrangler": "^4.95.0"
  }
}
